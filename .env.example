# ============================================================
# RETO.GG — Variables de entorno
# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas .env a GitHub
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=

# ── SUPABASE / POSTGRESQL ────────────────────────────────────
# Lo encuentras en: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=

# ── CLOUDINARY ──────────────────────────────────────────────
# Lo encuentras en: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ────────────────────────────────────────────────────
# En producción pon tu dominio real: https://retog.gg
ALLOWED_ORIGIN=
